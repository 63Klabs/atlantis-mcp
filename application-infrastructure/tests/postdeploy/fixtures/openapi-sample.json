  "components" : {
    "schemas" : {
      "MCPRequest" : {
        "required" : [ "id", "jsonrpc", "method" ],
        "type" : "object",
        "properties" : {
          "method" : {
            "type" : "string",
            "description" : "MCP method name to invoke"
          },
          "id" : {
            "description" : "Unique request identifier",
            "oneOf" : [ {
              "type" : "string"
            }, {
              "type" : "number"
            } ]
          },
          "jsonrpc" : {
            "type" : "string",
            "description" : "JSON-RPC protocol version",
            "enum" : [ "2.0" ]
          },
          "params" : {
            "type" : "object",
            "description" : "Method-specific parameters (optional)"
          }
        }
      },
      "MCPResponse" : {
        "required" : [ "id", "jsonrpc", "result" ],
        "type" : "object",
        "properties" : {
          "result" : {
            "type" : "object",
            "description" : "Method result data"
          },
          "id" : {
            "description" : "Request identifier matching the request",
            "oneOf" : [ {
              "type" : "string"
            }, {
              "type" : "number"
            } ]
          },
          "jsonrpc" : {
            "type" : "string",
            "description" : "JSON-RPC protocol version",
            "enum" : [ "2.0" ]
          }
        }
      },
      "MCPError" : {
        "required" : [ "error", "id", "jsonrpc" ],
        "type" : "object",
        "properties" : {
          "id" : {
            "description" : "Request identifier or null if request ID could not be determined",
            "oneOf" : [ {
              "type" : "string"
            }, {
              "type" : "number"
            }, null ]
          },
          "jsonrpc" : {
            "type" : "string",
            "description" : "JSON-RPC protocol version",
            "enum" : [ "2.0" ]
          },
          "error" : {
            "required" : [ "code", "message" ],
            "type" : "object",
            "properties" : {
              "code" : {
                "type" : "integer",
                "description" : "Error code (JSON-RPC standard codes)",
                "format" : "int32"
              },
              "data" : {
                "type" : "object",
                "description" : "Additional error information (optional)"
              },
              "message" : {
                "type" : "string",
                "description" : "Human-readable error message"
              }
            }
          }
        }
      }
    }
